  {
    "template_id": "mtpl_006",
    "intent_type": "sql_then_api",
    "n_steps": 2,
    "dag_shape": "linear",
    "n_parallel_steps": 1,
    "question_template": "Export a list of all destinations in the b2b-prod sandbox, sorted by most recently modified, including all columns associated with each destination, and include the 'modified' column for validation.",
    "step_templates": [
      {
        "step_id": "s1",
        "depends_on": [],
        "description": "Execute SQL query to retrieve data",
        "can_parallel": true,
        "action_type": "sql",
        "sql_template": "SELECT D.targetId AS target_id,\n       D.dataflowName AS dataflow_name,\n       D.name AS target_name,\n       D.description,\n       D.state,\n       D.connectionSpecId AS connection_spec_id,\n       D.{state}Time AS {state}_time,\n       D.{state}Time AS modified,\n       D.interval,\n       D.frequency\nFROM dim_target AS D\nORDER BY D.{state}Time DESC\nLIMIT {limit}"
      },
      {
        "step_id": "s2",
        "depends_on": [
          "s1"
        ],
        "description": "Make API call to https://platform.adobe.io/data/foundation/flowservice/flows",
        "can_parallel": false,
        "action_type": "api",
        "api_url_template": "https://platform.adobe.io/data/foundation/flowservice/flows",
        "api_params_template": "{\"limit\": \"{limit}\", \"sort\": \"{state}Time:desc\", \"property\": \"inheritedAttributes.properties.isDestinationFlow==true\"}"
      }
    ],
    "example_question": "Export a list of all destinations in the b2b-prod sandbox, sorted by most recently modified, including all columns associated with each destination, and include the 'modified' column for validation.",
    "react_turn_cost": 4,
    "schemaShortcut_turns": 3
  },
