  {
    "template_id": "mtpl_004",
    "intent_type": "sql_then_api",
    "n_steps": 3,
    "dag_shape": "linear",
    "n_parallel_steps": 1,
    "question_template": "List all segment audiences connected to the destination named '{destination}', showing audienceId, name, totalProfiles, {state}Time, {state}Time, and used in other audience count for each audience. Remove any row limit from the results.",
    "step_templates": [
      {
        "step_id": "s1",
        "depends_on": [],
        "description": "Execute SQL query to retrieve data",
        "can_parallel": true,
        "action_type": "sql",
        "sql_template": "SELECT \n    a.segmentid AS segment_id,\n    a.name AS segment_name,\n    a.totalmembers AS total_profiles,\n    a.{state}Time AS {state}_time,\n    a.{state}Time AS {state}_time\nFROM dim_segment a\nJOIN hkg_br_segment_target ad ON a.segmentid = ad.segmentid\nJOIN dim_target d ON ad.targetId = d.targetId\nWHERE d.dataflowName = '{destination}'\nORDER BY a.name"
      },
      {
        "step_id": "s2",
        "depends_on": [
          "s1"
        ],
        "description": "Make API call to https://platform.adobe.io/data/core/ups/audiences",
        "can_parallel": false,
        "action_type": "api",
        "api_url_template": "https://platform.adobe.io/data/core/ups/audiences",
        "api_params_template": "{\"property\": \"destinationId==<destination_id>\", \"limit\": \"{limit}\"}"
      },
      {
        "step_id": "s3",
        "depends_on": [
          "s2"
        ],
        "description": "Make API call to https://platform.adobe.io/data/foundation/flowservice/flows",
        "can_parallel": false,
        "action_type": "api",
        "api_url_template": "https://platform.adobe.io/data/foundation/flowservice/flows",
        "api_params_template": "{\"property\": \"inheritedAttributes.properties.isDestinationFlow==true\", \"limit\": \"{limit}\"}"
      }
    ],
    "example_question": "List all segment audiences connected to the destination named 'SMS Opt-In', showing audienceId, name, totalProfiles, createdTime, updatedTime, and used in other audience count for each audience. Remove any row limit from the results.",
    "react_turn_cost": 6,
    "schemaShortcut_turns": 3
  },
